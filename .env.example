# Server-side only — used by the /api/chat serverless function (api/chat.ts).
# NOT exposed to the browser (no VITE_ prefix). Set this in your Vercel project's
# Environment Variables, and locally create a .env with it then run `vercel dev`
# to test the chatbot.
GROQ_API_KEY=your_groq_api_key_here

# Optional — override the Groq model (defaults to llama-3.3-70b-versatile).
# GROQ_MODEL=llama-3.1-8b-instant

# Server-side only — used by the /api/contact serverless function (api/contact.ts)
# to email contact-form submissions via Resend. Get a free key at https://resend.com
# (sign up with kundalsunam@gmail.com so messages deliver without verifying a domain).
# Set this in your Vercel project's Environment Variables.
RESEND_API_KEY=your_resend_api_key_here

# Optional — where contact-form messages are delivered (defaults to kundalsunam@gmail.com).
# CONTACT_TO=kundalsunam@gmail.com

# Optional — the "from" sender. Defaults to Resend's shared test sender, which only
# delivers to your own account email. Set this to an address on a domain you've
# verified in Resend to send from your own domain, e.g. "Portfolio <contact@yourdomain.com>".
# CONTACT_FROM=Portfolio Contact <onboarding@resend.dev>
